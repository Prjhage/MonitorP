# Root .gitignore for both Client and Server

# Dependencies
**/node_modules/
**/package-lock.json (Optional, but often ignored in early development)
.pnp
.pnp.*

# Testing
**/coverage

# Next.js (Client)
client/.next/
client/out/

# Env files
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS Files
.DS_Store
Thumbs.db

# Production
client/build/
server/dist/

# Typescript
*.tsbuildinfo
next-env.d.ts
