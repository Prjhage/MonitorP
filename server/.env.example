# -------------------------------------------------------
# PRODUCTION (Render) - Set these in your Render service's
# Environment Variables settings before deploying.
# -------------------------------------------------------

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/api_monitor?appName=Cluster0

# Strong random secret for JWT signing (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_here

# Your Vercel frontend URL (no trailing slash) — used for CORS
FRONTEND_URL=https://monitor-p.vercel.app
